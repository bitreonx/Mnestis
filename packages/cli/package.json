{
  "name": "mnestis",
  "version": "0.3.2",
  "description": "Mnestis — the memory layer for software. One command, instant codebase intelligence.",
  "type": "module",
  "bin": {
    "mnestis": "bin/mnestis.cjs",
    "mnemos": "bin/mnemos-legacy.cjs",
    "getmnemos": "bin/getmnemos-legacy.cjs"
  },
  "main": "./dist/index.js",
  "files": [
    "bin",
    "dist/npm.cjs",
    "dist/discipline/fable-mindset.md",
    "README.md"
  ],
  "keywords": [
    "mnestis",
    "codebase-memory",
    "ai-coding",
    "architecture-intelligence",
    "cursor-mcp",
    "claude-code",
    "codex",
    "local-first",
    "dependency-graph",
    "ai-pack",
    "repository-dna",
    "developer-tools",
    "graphify-alternative",
    "codebase-analysis",
    "mcp-server"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitreonx/Mnestis.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/bitreonx/mnemos/issues"
  },
  "homepage": "https://mnestis.vercel.app",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "node scripts/bundle.mjs",
    "pkg": "node scripts/pkg.mjs",
    "prepare:publish": "node scripts/prepare-npm-publish.mjs",
    "validate:publish": "node scripts/validate-publish.mjs",
    "prepublishOnly": "npm run build --prefix ../core && npm run build && node scripts/prepare-npm-publish.mjs && node scripts/validate-publish.mjs",
    "postpublish": "node scripts/strip-publish-deps.mjs restore"
  },
  "dependencies": {
    "@mnestis/core": "*",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@yao-pkg/pkg": "^5.16.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
